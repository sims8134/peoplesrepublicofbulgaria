---

<MainLayout
  lang={lang}
  title={`${copy.title} | People's Republic of Bulgaria`}
  description={t.home.description}
  nav={buildNav(lang, t)}
  footer={buildFooter(lang, t)}
  active="videos"
  heroImage="/home/BackGroundHome.jpg"
>

<style>
.page-wrap {
  max-width: 1100px;
  margin: 0 auto;
  padding: 30px 20px;
}

.page-title {
  font-family: 'Oswald', sans-serif;
  font-size: 2.8rem;
  font-weight: 700;
  text-transform: uppercase;
  color: #f0ebe0;
  border-bottom: 3px solid #D62612;
  padding-bottom: 10px;
  margin-bottom: 8px;
}

.page-subtitle {
  font-size: 1.45rem;
  color: #888;
  margin-bottom: 28px;
  line-height: 1.6;
}

.tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  margin-bottom: 24px;
}

.tab-btn {
  padding: 9px 20px;
  background: #242424;
  border: 1px solid #333;
  color: #aaa;
  font-family: 'Oswald', sans-serif;
  font-size: 1.45rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  cursor: pointer;
}

.tab-btn:hover {
  background: #2e2e2e;
  color: #f0ebe0;
}

.tab-btn.active {
  background: #D62612;
  border-color: #D62612;
  color: #fff;
}

.tab-panel { display: none; }
.tab-panel.active { display: block; }

.player-box {
  background: #242424;
  border: 1px solid #333;
  padding: 16px;
  margin-bottom: 20px;
}

.player-embed {
  position: relative;
  padding-bottom: 56.25%;
  background: #000;
  margin-bottom: 14px;
}

.player-embed iframe {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  border: 0;
}

.player-meta h3 {
  font-family: 'Oswald', sans-serif;
  font-size: 2rem;
  font-weight: 700;
  color: #f0ebe0;
  margin-bottom: 6px;
}

.player-meta p {
  font-size: 1.4rem;
  color: #888;
  line-height: 1.7;
  margin-bottom: 14px;
}

.player-links {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.btn-red {
  display: inline-block;
  padding: 8px 18px;
  background: #D62612;
  color: #fff;
  font-family: 'Oswald', sans-serif;
  font-size: 1.4rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.btn-red:hover { background: #9B1B0C; }

.btn-outline {
  display: inline-block;
  padding: 8px 18px;
  background: transparent;
  color: #aaa;
  border: 1px solid #555;
  font-family: 'Oswald', sans-serif;
  font-size: 1.4rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.btn-outline:hover {
  color: #f0ebe0;
  border-color: #888;
}

.section-label {
  font-family: 'Oswald', sans-serif;
  font-size: 1.6rem;
  font-weight: 600;
  text-transform: uppercase;
  color: #888;
  border-bottom: 1px solid #333;
  padding-bottom: 6px;
  margin-bottom: 14px;
}

.thumb-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}

.thumb-card {
  background: #242424;
  border: 1px solid #333;
  cursor: pointer;
}

.thumb-card:hover { border-color: #D62612; }

.thumb-img {
  position: relative;
  aspect-ratio: 16 / 9;
  background: #111;
  overflow: hidden;
}

.thumb-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.thumb-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 3.2rem;
}

.thumb-body { padding: 10px 12px; }

.thumb-body h4 {
  font-family: 'Oswald', sans-serif;
  font-size: 1.5rem;
  color: #f0ebe0;
  margin-bottom: 3px;
}

.thumb-body p {
  font-size: 1.25rem;
  color: #666;
}

.subscribe-box {
  background: #D62612;
  padding: 24px;
  text-align: center;
  margin-top: 30px;
}

.subscribe-box h3 {
  font-family: 'Oswald', sans-serif;
  font-size: 2.2rem;
  font-weight: 700;
  text-transform: uppercase;
  color: #fff;
  margin-bottom: 8px;
}

.subscribe-box p {
  font-size: 1.4rem;
  color: rgba(255,255,255,0.8);
  margin-bottom: 16px;
}

.btn-white {
  display: inline-block;
  padding: 10px 26px;
  background: #fff;
  color: #D62612;
  font-family: 'Oswald', sans-serif;
  font-size: 1.5rem;
  font-weight: 700;
  text-transform: uppercase;
}

.btn-white:hover { background: #f0ebe0; }

@media (max-width: 700px) {
  .thumb-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 480px) {
  .thumb-grid { grid-template-columns: 1fr; }
  .player-links { flex-direction: column; }
}
</style>

<div class="page-wrap">
  <h1 class="page-title">{copy.title}</h1>
  <p class="page-subtitle">{copy.subtitle}</p>

  <div class="tabs">
    {categories.map((cat, index) => (
      <button class={`tab-btn ${index === 0 ? "active" : ""}`} data-tab={cat.key}>
        {cat.icon} {cat.key}
      </button>
    ))}
  </div>

  {categories.map((cat, index) => (
    <div class={`tab-panel ${index === 0 ? "active" : ""}`} id={`tab-${cat.key}`}>
      <div class="player-box">
        <div class="player-embed">
          <iframe
            id={`iframe-${cat.key}`}
            src={`https://www.youtube.com/embed/${cat.videoId}?rel=0`}
            title={cat.title}
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen>
          </iframe>
        </div>

        <div class="player-meta">
          <h3>{cat.title}</h3>
          <p>{cat.text}</p>
          <div class="player-links">
            <a href={`https://www.youtube.com/watch?v=${cat.videoId}`} target="_blank" class="btn-red">
              ▶ {copy.watch}
            </a>
            <a href={`https://www.youtube.com/playlist?list=${cat.playlist}`} target="_blank" class="btn-outline">
              ☰ {copy.playlist}
            </a>
          </div>
        </div>
      </div>

      <p class="section-label">{copy.more}</p>

      <div class="thumb-grid">
        {cat.thumbs.map((thumb) => (
          <div
            class="thumb-card"
            data-type={thumb.type}
            data-tab={cat.key}
            data-videoid={thumb.videoId || ""}
            data-playlist={cat.playlist}
          >
            <div class="thumb-img">
              {thumb.type === "video" ? (
                <img src={`https://img.youtube.com/vi/${thumb.videoId}/mqdefault.jpg`} alt={thumb.label} />
              ) : (
                <div class="thumb-placeholder">{cat.icon}</div>
              )}
            </div>
            <div class="thumb-body">
              <h4>{thumb.label}</h4>
              <p>{thumb.sub}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  ))}

  <div class="subscribe-box">
    <h3>{copy.subscribeTitle}</h3>
    <p>{copy.subscribeText}</p>
    <a
      href="https://www.youtube.com/@PeoplesRepublicOfBulgaria1505"
      target="_blank"
      class="btn-white"
    >
      ▶ {copy.subscribeBtn}
    </a>
  </div>
</div>

<script>
  document.querySelectorAll('.tab-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach((b) => b.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach((p) => p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById('tab-' + btn.dataset.tab)?.classList.add('active');
    });
  });

  function play(tab, videoId) {
    const iframe = document.getElementById('iframe-' + tab);
    if (!iframe) return;
    iframe.src = 'https://www.youtube.com/embed/' + videoId + '?autoplay=1&rel=0&modestbranding=1';
    document.getElementById('tab-' + tab)?.scrollIntoView({ behavior: 'smooth' });
  }

  document.querySelectorAll('.thumb-card').forEach((card) => {
    card.addEventListener('click', () => {
      const type = card.dataset.type;
      const tab = card.dataset.tab;
      const videoId = card.dataset.videoid;
      const playlist = card.dataset.playlist;

      if (type === 'video' && videoId) {
        play(tab, videoId);
      } else if (playlist) {
        window.open('https://www.youtube.com/playlist?list=' + playlist, '_blank');
      }
    });
  });
</script>

</MainLayout>